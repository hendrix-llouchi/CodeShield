@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <span class="fs-1 text-primary">🛡️</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-3">Dashboard</h1>
                    <p class="lead text-muted mb-4">
                        Welcome back, <strong class="text-dark">@User.Identity?.Name</strong>!
                    </p>
                    <div class="border-top pt-4">
                        <p class="text-muted small">
                            This is a placeholder page for the CodeShield security dashboard. The real dashboard features will be built here in future iterations.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
