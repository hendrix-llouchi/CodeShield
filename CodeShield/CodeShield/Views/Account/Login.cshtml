@model CodeShield.Models.LoginViewModel
@{
    ViewData["Title"] = "Log In";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="nb-card p-4 p-sm-5">
                <div class="text-center mb-4">
                    <img src="~/images/logo.jpg" alt="Valkyrie Logo" class="form-card-logo border border-3 border-dark rounded-0 mb-3" />
                    <h2 class="nb-heading mb-1">WELCOME BACK</h2>
                    <p class="nb-mono text-muted small text-uppercase">Log in to monitor your codebase security</p>
                </div>
                
                <form asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" novalidate>
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                    {
                        <div class="alert nb-alert-danger p-3 mb-4" role="alert">
                            <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label nb-mono fw-bold text-dark small text-uppercase"></label>
                        <input asp-for="Username" class="form-control nb-input" placeholder="Enter username" aria-required="true" />
                        <span asp-validation-for="Username" class="text-danger nb-mono small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label asp-for="Password" class="form-label nb-mono fw-bold text-dark small text-uppercase mb-0"></label>
                            <a href="#" class="text-decoration-none small nb-nav-link fw-bold" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal">Forgot password?</a>
                        </div>
                        <div class="nb-input-group">
                            <input asp-for="Password" type="password" id="passwordInput" class="form-control nb-input" placeholder="••••••••" aria-required="true" />
                            <button type="button" class="nb-password-toggle" id="togglePasswordBtn" aria-label="Toggle password visibility">
                                <span id="togglePasswordIcon">👁️</span>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger nb-mono small mt-1 d-block"></span>
                    </div>

                    <div class="form-check d-flex align-items-center gap-2 mb-4">
                        <input class="form-check-input nb-checkbox m-0" asp-for="RememberMe" />
                        <label asp-for="RememberMe" class="form-check-label nb-mono small text-muted">
                            Remember my login
                        </label>
                    </div>

                    <button class="w-100 nb-btn nb-btn-primary mb-3" type="submit">Log In</button>
                    
                    <div class="text-center mt-3">
                        <p class="nb-mono small mb-0">
                            New to Valkyrie? <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold nb-nav-link text-primary">Create an account</a>.
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Forgot Password Info Modal -->
<div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content nb-modal-content">
            <div class="modal-header nb-modal-header d-flex align-items-center justify-content-between">
                <h5 class="modal-title fw-bold text-dark d-flex align-items-center gap-2" id="forgotPasswordModalLabel">
                    <span>🔑</span> Password Recovery
                </h5>
                <button type="button" class="btn-close rounded-0" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body nb-modal-body text-secondary">
                <div class="text-center mb-4">
                    <span class="fs-1">🌐</span>
                    <h6 class="fw-bold mt-2 text-dark">Local Sandbox Environment</h6>
                </div>
                <p class="small">
                    This instance of <strong>Valkyrie</strong> is running as a local security tool with no connection to external SMTP/Gmail or SMS services.
                </p>
                <p class="small mb-0">
                    If you've forgotten your password, you can:
                </p>
                <ul class="small mt-2 ps-3">
                    <li class="mb-1"><strong>Register a new username</strong> to continue scanning public repositories.</li>
                    <li>Contact your local system administrator to reset or re-seed the credentials from the database.</li>
                </ul>
            </div>
            <div class="modal-footer nb-modal-footer">
                <button type="button" class="nb-btn nb-btn-secondary w-100" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('#togglePasswordBtn').click(function () {
                const passwordInput = $('#passwordInput');
                const icon = $('#togglePasswordIcon');
                
                if (passwordInput.attr('type') === 'password') {
                    passwordInput.attr('type', 'text');
                    icon.text('🙈');
                } else {
                    passwordInput.attr('type', 'password');
                    icon.text('👁️');
                }
            });
        });
    </script>
}
